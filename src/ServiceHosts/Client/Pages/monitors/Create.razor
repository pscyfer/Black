@page "/Monitors/Create"
<PageTitle>افزودن سرویس جدید</PageTitle>

<RadzenFieldset Text="افزودن واکشی جدید">
    <RadzenRow>
        <RadzenColumn SizeSM="12" SizeMD="3">
            <RadzenFormField Text="نام" Style="width:100%">
                <RadzenTextBox @bind-Value="@Name" />
            </RadzenFormField>
        </RadzenColumn>
        <RadzenColumn SizeSM="12" SizeMD="3">
            <RadzenFormField Style="width:100%" Text="آدرس">
                <ChildContent>
                    <RadzenTextBox @bind-Value="@HostAddress" />
                </ChildContent>
            </RadzenFormField>
        </RadzenColumn>
        <RadzenColumn SizeSM="12" SizeMD="3">
            <RadzenFormField Text="مدت زمان درخواست" Style="width:100%">
                <ChildContent>
                    <RadzenNumeric @bind-Value="@Interval" />
                </ChildContent>
            </RadzenFormField>
        </RadzenColumn>
        <RadzenColumn SizeSM="12" SizeMD="3">
            <RadzenFormField Text="مدت زنان منتظر ماندن برای پاسخ" Style="width:100%">
                <ChildContent>
                    <RadzenNumeric @bind-Value="@Timeout" />
                </ChildContent>
            </RadzenFormField>
        </RadzenColumn>
        <RadzenColumn SizeSM="12" SizeMD="3">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenLabel Text="SSL چک شود" />
                <RadzenSwitch @bind-Value="IsSslCheck" />
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn SizeSM="12" SizeMD="3">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenLabel Text="تاریخ انقضای دامنه چک شود؟" />
                <RadzenSwitch @bind-Value="IsDomainExpierCheck" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>
    <RadzenRow class="mt-5">
        <RadzenColumn class="justify-content-center" Size="12">
            <RadzenButton Text="ثبت" ButtonStyle="ButtonStyle.Success" />
            <RadzenLink Path="/MyServices">
                <RadzenButton Text="برگشت" ButtonStyle="ButtonStyle.Secondary" />
            </RadzenLink>
        </RadzenColumn>
    </RadzenRow>
</RadzenFieldset>

